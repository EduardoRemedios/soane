#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys


SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from factory_context_index import (  # noqa: E402
    FactoryContextIndexError,
    build_context_index,
    describe_context,
    expand_context,
    format_context_describe,
    format_context_expand,
    format_context_recall,
    format_context_trace,
    recall_context,
    trace_context,
    write_context_report,
)
from factory_kilo_stage import (  # noqa: E402
    FactoryKiloStageError,
    format_kilo_stage,
    run_kilo_stage,
)
from factory_pack_lint import (  # noqa: E402
    FactoryPackLintError,
    format_pack_lint,
    lint_pack,
)
from factory_run_metrics import (  # noqa: E402
    FactoryRunMetricsError,
    format_run_metrics,
    init_run_metrics,
)
from factory_stage_lint import (  # noqa: E402
    FactoryStageLintError,
    format_stage_lint,
    lint_stage,
)
from factory_task_memory import (  # noqa: E402
    TaskMemoryError,
    bootstrap_task_memory,
    format_suggestion_text,
    log_task,
    review_task_memory,
    suggest_task,
)


REPO_ROOT = SCRIPT_DIR.parent


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="factoryctl",
        description="Factory continuity, context-recall, validation, and optional task-memory helper.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    memory_init_parser = subparsers.add_parser(
        "memory-init",
        help="Initialize optional task-memory directories, default runbooks, and journal.",
    )
    memory_init_parser.add_argument("--force", action="store_true", help="Rewrite default runbooks and clear journal.")
    memory_init_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    memory_suggest_parser = subparsers.add_parser(
        "memory-suggest",
        help="Classify a task and print the best runbook checklist.",
    )
    memory_suggest_parser.add_argument("--task", required=True, help="Task description to classify.")
    memory_suggest_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    memory_log_parser = subparsers.add_parser(
        "memory-log",
        help="Append one task outcome to the optional task-memory journal.",
    )
    memory_log_parser.add_argument("--task", required=True, help="Task description.")
    memory_log_parser.add_argument(
        "--outcome",
        required=True,
        choices=["success", "partial", "blocked"],
        help="Task result status.",
    )
    memory_log_parser.add_argument("--notes", default="", help="Short lessons learned or failure details.")
    memory_log_parser.add_argument("--runbook", default=None, help="Optional explicit runbook id.")
    memory_log_parser.add_argument("--duration-minutes", type=int, default=None, help="Optional duration in minutes.")
    memory_log_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    memory_review_parser = subparsers.add_parser(
        "memory-review",
        help="Summarize task-memory journal trends and optionally write a review report.",
    )
    memory_review_parser.add_argument("--no-write-report", action="store_true", help="Print summary without writing a markdown report.")
    memory_review_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_index_parser = subparsers.add_parser(
        "context-index",
        help="Build the Factory, Mission, and Product Owner artifact recall index.",
    )
    context_index_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_index_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_recall_parser = subparsers.add_parser(
        "context-recall",
        help="Search indexed Factory, Mission, and Product Owner artifacts.",
    )
    context_recall_parser.add_argument("--query", required=True, help="Recall query.")
    context_recall_parser.add_argument("--scope", default=None, help="Optional path, run, phase, mission, or sprint filter.")
    context_recall_parser.add_argument("--limit", type=int, default=8, help="Maximum number of matches to return.")
    context_recall_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_recall_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_trace_parser = subparsers.add_parser(
        "context-trace",
        help="Trace an exact identifier such as RUN_..., PHASE_..., Pxx-yy, C-..., or FP-....",
    )
    context_trace_parser.add_argument("--id", required=True, help="Identifier to trace.")
    context_trace_parser.add_argument("--scope", default=None, help="Optional path, run, phase, mission, or sprint filter.")
    context_trace_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_trace_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_expand_parser = subparsers.add_parser(
        "context-expand",
        help="Expand one indexed chunk by numeric chunk id or one indexed source by path.",
    )
    context_expand_parser.add_argument("--ref", required=True, help="Chunk id or indexed source path.")
    context_expand_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_expand_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_describe_parser = subparsers.add_parser(
        "context-describe",
        help="Describe indexed source coverage by artifact type and scope.",
    )
    context_describe_parser.add_argument("--scope", default=None, help="Optional path, run, phase, mission, or sprint filter.")
    context_describe_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_describe_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    context_report_parser = subparsers.add_parser(
        "context-report",
        help="Generate a scoped context recall report artifact for Factory, PO, or Mission workflows.",
    )
    context_report_parser.add_argument(
        "--profile",
        required=True,
        choices=["stage-a", "po-brief", "mission-checkpoint"],
        help="Report profile.",
    )
    context_report_parser.add_argument("--scope", required=True, help="Required path, run, phase, mission, or sprint scope filter.")
    context_report_parser.add_argument("--output", required=True, help="Output path for the markdown report artifact.")
    context_report_parser.add_argument("--focus", action="append", default=[], help="Optional focus term; may be repeated.")
    context_report_parser.add_argument("--trace-id", action="append", default=[], help="Optional exact identifier to trace; may be repeated.")
    context_report_parser.add_argument("--fallback-scope", action="append", default=[], help="Optional broader scope to try after the requested scope; may be repeated.")
    context_report_parser.add_argument("--required-ref", action="append", default=[], help="Optional exact identifier or exact source path that must resolve in the final report; may be repeated.")
    context_report_parser.add_argument("--query", action="append", default=[], help="Optional extra recall query; may be repeated.")
    context_report_parser.add_argument("--limit", type=int, default=5, help="Maximum matches to include per query.")
    context_report_parser.add_argument("--db-path", default=None, help="Optional override for the SQLite index path.")
    context_report_parser.add_argument("--fail-on-weak-coverage", action="store_true", help="Exit non-zero after writing the report if coverage remains WEAK after all attempted scopes.")
    context_report_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    pack_lint_parser = subparsers.add_parser(
        "pack-lint",
        help="Validate a completed Factory run pack after Stage I2.",
    )
    pack_lint_group = pack_lint_parser.add_mutually_exclusive_group(required=True)
    pack_lint_group.add_argument("--run", default=None, help="Run ID or run-root path to validate.")
    pack_lint_group.add_argument("--pack", default=None, help="Direct path to a run pack directory.")
    pack_lint_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    stage_lint_parser = subparsers.add_parser(
        "stage-lint",
        help="Validate one Factory stage handoff and its expected outputs.",
    )
    stage_lint_parser.add_argument("--run", required=True, help="Run ID or run-root path to validate.")
    stage_lint_parser.add_argument(
        "--stage",
        required=True,
        choices=["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "I2"],
        help="Factory stage code to validate.",
    )
    stage_lint_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    kilo_stage_parser = subparsers.add_parser(
        "kilo-stage",
        help="Run one Factory stage through Kilo Code CLI with model routing and write-boundary checks.",
    )
    kilo_stage_parser.add_argument("--run", required=True, help="Run ID or run-root path.")
    kilo_stage_parser.add_argument(
        "--stage",
        required=True,
        choices=["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "I2"],
        help="Factory stage code to run.",
    )
    kilo_stage_parser.add_argument("--model", required=True, help="Kilo model id, for example kilo/openai/gpt-5.5.")
    kilo_stage_parser.add_argument("--variant", default=None, help="Optional model variant or reasoning effort, for example high.")
    kilo_stage_parser.add_argument("--agent", default=None, help="Optional Kilo agent name.")
    kilo_stage_parser.add_argument("--kilo-bin", default="kilo", help="Kilo CLI binary path.")
    kilo_stage_parser.add_argument("--auto", action="store_true", help="Pass --auto to Kilo for non-interactive execution.")
    kilo_stage_parser.add_argument("--timeout-seconds", type=int, default=900, help="Kilo process timeout in seconds.")
    kilo_stage_parser.add_argument(
        "--allow-nested-kilo",
        action="store_true",
        help="Allow invoking kilo-stage from inside a Kilo parent process. Not recommended.",
    )
    kilo_stage_parser.add_argument("--dry-run", action="store_true", help="Print the generated command and prompt without invoking Kilo.")
    kilo_stage_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    metrics_init_parser = subparsers.add_parser(
        "metrics-init",
        help="Create RUN_METRICS.md for a Factory run from the canonical template.",
    )
    metrics_init_parser.add_argument("--run", required=True, help="Run ID or run-root path.")
    metrics_init_parser.add_argument("--force", action="store_true", help="Overwrite an existing RUN_METRICS.md.")
    metrics_init_parser.add_argument("--json", action="store_true", help="Print JSON output.")

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    root = REPO_ROOT

    try:
        if args.command == "memory-init":
            payload = bootstrap_task_memory(root=root, force=args.force)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(f"Task memory initialized: {payload['journal_path']}")
                for path in payload["runbooks_written"]:
                    print(f"Runbook written: {path}")
            return 0

        if args.command == "memory-suggest":
            payload = suggest_task(root=root, task=args.task)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_suggestion_text(payload))
            return 0

        if args.command == "memory-log":
            payload = log_task(
                root=root,
                task=args.task,
                outcome=args.outcome,
                notes=args.notes,
                runbook_id=args.runbook,
                duration_minutes=args.duration_minutes,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(f"Task memory logged: {payload['entry_id']} runbook={payload['runbook_id']} outcome={payload['outcome']}")
            return 0

        if args.command == "memory-review":
            payload = review_task_memory(root=root, write_report=not args.no_write_report)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(payload["report"], end="")
                if payload["report_path"]:
                    print(f"\nReport written: {payload['report_path']}")
            return 0

        if args.command == "context-index":
            payload = build_context_index(root=root, db_path=Path(args.db_path) if args.db_path else None)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(f"Factory context index rebuilt: {payload['db_path']}")
                print(f"Sources={payload['source_count']} Chunks={payload['chunk_count']} Facts={payload['fact_count']}")
            return 0

        if args.command == "context-recall":
            payload = recall_context(
                root=root,
                query=args.query,
                db_path=Path(args.db_path) if args.db_path else None,
                scope=args.scope,
                limit=args.limit,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_context_recall(payload), end="")
            return 0

        if args.command == "context-trace":
            payload = trace_context(
                root=root,
                identifier=args.id,
                db_path=Path(args.db_path) if args.db_path else None,
                scope=args.scope,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_context_trace(payload), end="")
            return 0

        if args.command == "context-expand":
            payload = expand_context(
                root=root,
                ref=args.ref,
                db_path=Path(args.db_path) if args.db_path else None,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_context_expand(payload), end="")
            return 0

        if args.command == "context-describe":
            payload = describe_context(
                root=root,
                db_path=Path(args.db_path) if args.db_path else None,
                scope=args.scope,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_context_describe(payload), end="")
            return 0

        if args.command == "context-report":
            payload = write_context_report(
                root=root,
                output_path=Path(args.output),
                profile=args.profile,
                scope=args.scope,
                focus_terms=args.focus,
                trace_ids=args.trace_id,
                fallback_scopes=args.fallback_scope,
                required_refs=args.required_ref,
                additional_queries=args.query,
                limit=args.limit,
                db_path=Path(args.db_path) if args.db_path else None,
                fail_on_weak_coverage=args.fail_on_weak_coverage,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(f"Context recall report written: {payload['output_path']}")
                print(
                    f"Profile={payload['profile']} RequestedScope={payload['requested_scope']} "
                    f"EffectiveScope={payload['effective_scope']} Coverage={payload['coverage_verdict']} "
                    f"Queries={payload['query_count']} Traces={payload['trace_count']}"
                )
            return 0

        if args.command == "pack-lint":
            payload = lint_pack(
                root=root,
                run=args.run,
                pack_path=Path(args.pack) if args.pack else None,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_pack_lint(payload), end="")
            return 0 if payload["status"] == "PASS" else 1

        if args.command == "stage-lint":
            payload = lint_stage(root=root, run=args.run, stage=args.stage)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_stage_lint(payload), end="")
            return 0 if payload["status"] == "PASS" else 1

        if args.command == "kilo-stage":
            payload = run_kilo_stage(
                root=root,
                run=args.run,
                stage=args.stage,
                model=args.model,
                variant=args.variant,
                agent=args.agent,
                kilo_bin=args.kilo_bin,
                auto=args.auto,
                timeout_seconds=args.timeout_seconds,
                dry_run=args.dry_run,
                allow_nested_kilo=args.allow_nested_kilo,
            )
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_kilo_stage(payload), end="")
            return 0 if payload["status"] in {"PASS", "DRY_RUN"} else 1

        if args.command == "metrics-init":
            payload = init_run_metrics(root=root, run=args.run, force=args.force)
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print(format_run_metrics(payload), end="")
            return 0

    except (
        FactoryContextIndexError,
        FactoryKiloStageError,
        FactoryPackLintError,
        FactoryRunMetricsError,
        FactoryStageLintError,
        TaskMemoryError,
    ) as exc:
        print(f"ERROR: {exc}")
        return 2

    parser.print_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
